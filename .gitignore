# ════════════════════════════════════════════════════════════════════════════
# BioLab .gitignore — Sprint 0 GAP-01/GAP-03 additions
#
# Add these lines to the ROOT .gitignore of the project.
# They prevent secrets, IDE files, and build artefacts from being committed.
# ════════════════════════════════════════════════════════════════════════════

# ── Secret / credential files ────────────────────────────────────────────────
.env
.env.*
!.env.example          # Allow the template to be committed
*.p12                  # PKCS12 keystores
*.jks                  # Java keystores
*.pem
*.key
secrets/

# ── Java compiled classes ────────────────────────────────────────────────────
*.class

# ── Maven / Gradle outputs ───────────────────────────────────────────────────
target/
build/
out/

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
.vscode/
*.swp

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
